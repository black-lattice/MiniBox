<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.minibox</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/minibox</string>
    <string>/etc/minibox/source</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/opt/minibox</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/var/log/minibox.out.log</string>

  <key>StandardErrorPath</key>
  <string>/var/log/minibox.err.log</string>
</dict>
</plist>
